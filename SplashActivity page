// activity_splash.xml (The Layout Displayed on the App)
    <?xml version="1.0" encoding="utf-8"?>
    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@drawable/splash_bg_gradient">
    
        <!-- Icon -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_cat"
            android:layout_marginBottom="30dp"/>
    
        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SmartCatBox"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    
        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tech for Paws: A Warm Home for Strays"
            android:textSize="16sp"
            android:textColor="#F5F5F5"
            android:layout_marginTop="16dp"/>
    
        <!-- Enter Button -->
        <Button
            android:id="@+id/btn_enter_app"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="Enter"
            android:textSize="18sp"
            android:layout_marginTop="80dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#333333"/>
    
    </LinearLayout>

  // SplashActivity.kts (Code that Makes the Layout Working)
    package com.example.smartcatbox
    
    import android.content.Intent
    import android.os.Bundle
    import android.widget.Button
    import android.widget.Toast
    import androidx.appcompat.app.AppCompatActivity
    
    class SplashActivity : AppCompatActivity() {
        override fun onCreate(savedInstanceState: Bundle?) {
            super.onCreate(savedInstanceState)
            setContentView(R.layout.activity_splash)
    
            // Finding enter button
            val btnEnterApp = findViewById<Button>(R.id.btn_enter_app)
    
            // Jump to RegisterActivity page
            btnEnterApp.setOnClickListener {
                Toast.makeText(this, "Welcome to SmartCatBox～", Toast.LENGTH_SHORT).show()
                val intent = Intent(this, MainActivity::class.java)
                startActivity(intent)
                finish() // Never Coming back
            }
        }
    }
